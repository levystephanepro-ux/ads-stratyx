# --- Supabase (auth + base de données) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Clé service_role : UNIQUEMENT côté serveur (jamais exposée au navigateur).
# Sert au serveur MCP à lire/écrire les tokens sans passer par la session utilisateur.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- URL publique de l'app (pour construire l'URL MCP et les callbacks OAuth) ---
# En local : http://localhost:3000  |  En prod : https://ton-domaine.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Sécurité MCP : token secret exigé pour appeler /api/mcp en mono-compte ---
# Génère-en un : node -e "console.log('mcp_'+require('crypto').randomBytes(24).toString('base64url'))"
# OBLIGATOIRE avant toute exposition publique (sinon accès libre à ton compte Ads).
MCP_SHARED_TOKEN=

# --- Mode de données Google Ads ---
# mock  = données factices, aucun accès Google Ads requis (par défaut, pour développer)
# live  = vrais appels à l'API Google Ads (nécessite les identifiants ci-dessous)
ADS_DATA_MODE=mock

# --- Google Ads API (requis uniquement en mode live) ---
# Version de l'API. Une SEULE source de vérité : on la change ici quand Google déprécie.
# À vérifier sur https://developers.google.com/google-ads/api/docs/release-notes
GOOGLE_ADS_API_VERSION=v21
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
# Compte MCC "manager" qui chapeaute les comptes clients (facultatif au début).
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Google Search Console ---
# mock = données demo | live = vrais appels API
SEARCH_CONSOLE_DATA_MODE=mock
# Refresh token avec scope webmasters.readonly.
# Si le même OAuth app que Google Ads, laisser vide → réutilise GOOGLE_ADS_REFRESH_TOKEN.
GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=
